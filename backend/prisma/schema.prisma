// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    BigInt       @id @default(autoincrement()) @map("id")
  openid                String       @unique @map("openid") @db.VarChar(64)
  freeCount             Int          @default(3) @map("free_count")
  rewardCount           Int          @default(0) @map("reward_count")
  usedToday             Int          @default(0) @map("used_today")
  totalUses             Int          @default(0) @map("total_uses")
  disclaimerAccepted    Boolean      @default(false) @map("disclaimer_accepted")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  contacts              Contact[]
  feedbacks             Feedback[]
  chatRecords           ChatRecord[]
}

model Contact {
  id                    BigInt       @id @default(autoincrement()) @map("id")
  openid                String       @map("openid") @db.VarChar(64)
  nickname              String       @map("nickname") @db.VarChar(50)
  avatar                String?      @map("avatar") @db.VarChar(255)
  identities            Json?        @map("identities")            // 多选身份数组，如 ["crush", "ambiguous"]
  identity_labels       Json?        @map("identity_labels")       // 中文标签数组，如 ["暗恋对象", "暧昧对象"]
  target                Json?        @map("target")                // 回复目标数组，如 ["flirt", "proactive"]
  target_labels         Json?        @map("target_labels")         // 回复目标中文标签
  style                 Json?        @map("style")                 // 回复风格数组，如 ["gentle", "humor"]
  style_labels          Json?        @map("style_labels")          // 回复风格中文标签
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  user                  User         @relation(fields: [openid], references: [openid])
  chatRecords           ChatRecord[]
}

model ChatRecord {
  id                    BigInt       @id @default(autoincrement()) @map("id")
  openid                String       @map("openid") @db.VarChar(64)
  contactId             BigInt?      @map("contact_id")
  message               String       @map("message") @db.Text        // 用户输入的消息/前情提要
  context               String?      @map("context") @db.Text        // 前情提要
  pace                  Int?         @map("pace")                    // 聊天节奏 0-100
  persona               String?      @map("persona")                 // 人设
  thoughts              Json?        @map("thoughts")                // 想法选项
  thoughtCustom         String?      @map("thought_custom") @db.Text  // 自定义想法
  resultThinking        String?      @map("result_thinking") @db.Text  // AI 分析结果
  resultRemind          String?      @map("result_remind") @db.Text
  resultReplies         Json?        @map("result_replies")          // 回复建议数组
  createdAt             DateTime     @default(now()) @map("created_at")

  contact               Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user                  User         @relation(fields: [openid], references: [openid])
}

model Feedback {
  id                    BigInt       @id @default(autoincrement()) @map("id")
  openid                String       @map("openid") @db.VarChar(64)
  content               String       @map("content") @db.Text
  images                Json?        @map("images")
  contact               String?      @map("contact") @db.VarChar(50)
  createdAt             DateTime     @default(now()) @map("created_at")

  user                  User         @relation(fields: [openid], references: [openid])
}
