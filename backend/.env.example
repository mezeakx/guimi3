# 环境变量模板
# 复制此文件为 .env 并填入实际值

# 数据库
DATABASE_URL=mysql://user:password@localhost:3306/guimi

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d

# AI
AI_API_KEY=your-ai-api-key
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1

# 微信
WX_APP_ID=your-wechat-appid
WX_APP_SECRET=your-wechat-appsecret

# OCR
OCR_API_KEY=your-ocr-api-key

# 端口
PORT=3000
