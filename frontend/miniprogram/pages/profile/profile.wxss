/* pages/profile/profile.wxss */
.user-card {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 16rpx;
  padding: 40rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 24rpx;
}

.user-stats {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #FF69B4;
  line-height: 1;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-label {
  font-size: 22rpx;
  color: #666666;
  margin-top: 4rpx;
}

.stat-icon {
  font-size: 40rpx;
  line-height: 1;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #FFF5F8;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* ========== 免责声明弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.modal-content {
  width: 640rpx;
  height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 2rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
}

.modal-scroll {
  flex: 1;
  min-height: 0;
}

.modal-body {
  padding: 24rpx 32rpx;
}

.intro {
  background: #FFF5F8;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #FF69B4;
}

.intro-text {
  font-size: 24rpx;
  color: #555555;
  line-height: 1.8;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.section-title .num {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-right: 4rpx;
}

.section-title .name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.section .text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  display: block;
  margin-bottom: 8rpx;
}

.list {
  margin-bottom: 8rpx;
  padding-left: 20rpx;
}

.list .item {
  font-size: 26rpx;
  color: #555555;
  line-height: 2;
  display: block;
  position: relative;
  padding-left: 20rpx;
}

.list .item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #FF69B4;
}

.footer-note {
  margin-top: 24rpx;
  padding: 16rpx;
  background: #FFF9EC;
  border-radius: 12rpx;
  border: 2rpx dashed #FFB800;
}

.footer-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

.modal-footer {
  padding: 20rpx 32rpx;
  padding-bottom: 48rpx;
  border-top: 2rpx solid #F0F0F0;
  flex-shrink: 0;
}

.btn-accept {
  width: 100%;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

/* ========== 清空数据确认弹窗 ========== */
.modal-content--small {
  height: auto;
  max-height: 60vh;
  min-height: 300rpx;
}

.modal-body--compact {
  padding: 40rpx 32rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  text-align: center;
}

.modal-footer--two {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 20rpx 32rpx 48rpx;
}

.modal-footer--two button {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  padding: 20rpx 0;
  margin: 0;
  line-height: 1.4;
}

.btn-cancel {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  border: none;
}

.btn-confirm-danger {
  background: #F5F5F5;
  color: #666666;
  border: none;
}
