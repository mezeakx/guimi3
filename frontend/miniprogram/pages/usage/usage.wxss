.container { padding: 24rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; text-align: center; margin-bottom: 40rpx; }
.steps { padding: 0 16rpx; }
.step { display: flex; align-items: center; margin-bottom: 32rpx; background: #fff; padding: 24rpx; border-radius: 16rpx; }
.step-icon { font-size: 48rpx; margin-right: 24rpx; }
.step-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.step-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.tip { font-size: 24rpx; color: #999; text-align: center; margin-top: 40rpx; }
