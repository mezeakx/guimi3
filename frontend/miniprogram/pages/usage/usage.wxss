/* pages/usage/usage.wxss */

.page-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding: 0 32rpx 40rpx;
}

/* ========== Header ========== */
.header-section {
  padding: 40rpx 0 32rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

/* ========== Timeline ========== */
.timeline-section {
  margin-bottom: 40rpx;
}

.timeline-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.timeline-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

/* Step Number Circle */
.timeline-number {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  z-index: 1;
}

.number-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #FFFFFF;
}

/* Vertical Connector Line */
.timeline-connector {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #FF69B4, rgba(155, 89, 182, 0.2));
  margin-left: 27rpx;
  flex-shrink: 0;
}

/* Step Content */
.timeline-content {
  flex: 1;
  padding-left: 24rpx;
  padding-top: 4rpx;
}

.content-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.content-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.content-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.content-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

/* ========== Tips ========== */
.tips-section {
  margin-top: 8rpx;
}

.section-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-emoji {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.section-heading {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.tip-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 8rpx 0;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tip-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 24rpx 28rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}
