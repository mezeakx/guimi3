<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部标题区域 -->
  <view class="header-section">
    <text class="header-title">闺蜜帮你回 💕</text>
    <text class="header-subtitle">你的专属聊天军师，帮你想出高情商回复</text>
  </view>

  <!-- 输入方式切换 -->
  <view class="input-mode-tabs">
    <view class="tab {{inputMode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="switchInputMode">
      <text class="tab-icon">💬</text>
      <text>文字输入</text>
    </view>
    <view class="tab {{inputMode === 'image' ? 'active' : ''}}" data-mode="image" bindtap="switchInputMode">
      <text class="tab-icon">🖼️</text>
      <text>上传截图</text>
    </view>
  </view>

  <!-- 文字输入模式 -->
  <view class="card" wx:if="{{inputMode === 'text'}}">
    <!-- 他的消息 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">他的消息</text>
      </view>
      <textarea
        class="input-field message-input"
        placeholder="把他的消息复制过来，或者手动输入..."
        value="{{message}}"
        maxlength="{{maxMessage}}"
        auto-height
        bindinput="onMessageInput"
      />
      <view class="char-count">{{charCount}}/{{maxMessage}}</view>
    </view>

    <!-- 前情提要 -->
    <view class="section mt-24">
      <view class="section-header purple">
        <text class="section-title">前情提要 <text class="subtitle">（选填）</text></text>
        <text class="help-icon">?</text>
      </view>
      <textarea
        class="input-field context-input"
        placeholder="比如：你们刚认识一周，他平时比较主动..."
        value="{{context}}"
        maxlength="{{maxContext}}"
        auto-height
        bindinput="onContextInput"
      />
      <view class="char-count">{{contextCount}}/{{maxContext}}</view>
    </view>

    <!-- 生成按钮 -->
    <button class="btn-gradient submit-btn" bindtap="generateReply" disabled="{{generating}}">
      <text wx:if="{{!generating}}">✨ 生成回复建议</text>
      <text wx:else>分析中...</text>
    </button>

    <view class="footer-tip">🛡 内容仅供参考，请结合实际情况判断</view>
  </view>

  <!-- 上传截图模式 -->
  <view class="card" wx:if="{{inputMode === 'image'}}">
    <view class="upload-area" bindtap="uploadImage">
      <text class="upload-icon">📷</text>
      <text class="upload-text">点击上传聊天截图</text>
      <text class="upload-hint">支持 OCR 识别，单图最大 2MB</text>
    </view>
  </view>

  <!-- 最近联系人 -->
  <view class="recent-section mt-24">
    <view class="section-header flex-between">
      <text class="section-title">最近联系人</text>
      <text class="manage-link" bindtap="goToContacts">管理 ></text>
    </view>
    <view class="recent-grid">
      <!-- 新增联系人 -->
      <navigator url="/pages/contact-create/contact-create" class="contact-card add-contact">
        <view class="add-avatar">+</view>
        <text>新增</text>
      </navigator>
      <!-- 已有联系人 -->
      <view
        wx:for="{{recentContacts}}"
        wx:key="_contactId"
        class="contact-card {{item._isSelected ? 'contact-selected' : ''}}"
        data-id="{{item._contactId}}"
        bindtap="toggleContactSelect"
      >
        <image class="contact-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="select-indicator" wx:if="{{item._isSelected}}">
          <text class="check-icon">✓</text>
        </view>
        <text class="contact-name">{{item.nickname}}</text>
        <text class="contact-tag">{{item.identity_label_display}}</text>
      </view>
    </view>
  </view>

  <!-- 推广横幅 -->
  <navigator url="/pages/usage/usage" class="promo-banner mt-24" hover-class="promo-hover">
    <view class="promo-icon">📖</view>
    <view class="promo-content">
      <text class="promo-title">不会回消息？</text>
      <text class="promo-desc">让闺蜜帮你想，让他越来越喜欢你</text>
    </view>
    <view class="promo-arrow">></view>
  </navigator>
</view>