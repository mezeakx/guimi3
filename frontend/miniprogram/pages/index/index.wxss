/* pages/index/index.wxss */

/* 顶部标题区域 */
.header-section {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

.input-mode-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #FF69B4;
  border-bottom-color: #FF69B4;
  background: #FFF5F8;
}

.tab-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-header.pink .section-title::before {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
}

.section-title::before {
  content: "";
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  vertical-align: middle;
  background: #FF69B4;
}

.section-header.purple .section-title::before {
  background: #9B59B6;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.subtitle {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}

.help-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #999999;
  color: #999999;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8rpx;
}

.message-input {
  min-height: 200rpx;
  max-height: 400rpx;
}

.context-input {
  min-height: 120rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ========== 关系状态选项 ========== */
.relationship-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.rel-tag {
  padding: 12rpx 28rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.rel-tag:active {
  opacity: 0.7;
}

.rel-tag.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

/* ========== 提交按钮 ========== */
.submit-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.submit-btn:disabled {
  opacity: 0.6;
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  border: 4rpx dashed #FF69B4;
  border-radius: 16rpx;
  background: #FFF5F8;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
}


/* ========== 我的想法模块 ========== */
.my-thoughts-section {
  margin-bottom: 24rpx;
}

.thought-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
  padding-bottom: 8rpx;
}

.thought-tab {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.thought-tab:active {
  opacity: 0.7;
}

.thought-tab.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.thought-tab text {
  font-size: 24rpx;
}

.thought-options-wrapper {
  margin-bottom: 16rpx;
}

.thought-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.thought-option {
  padding: 12rpx 28rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.2s ease;
}

.thought-option:active {
  opacity: 0.7;
}

.thought-option.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

.thought-custom-input {
  min-height: 100rpx;
  max-height: 200rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 0 20rpx;
  margin-top: 8rpx;
}
.recent-section {
  margin-top: 32rpx;
}

.manage-link {
  font-size: 24rpx;
  color: #999999;
}

/* ========== 已选联系人标签区域 ========== */
.selected-tags-section {
  margin-bottom: 24rpx;
}

.clear-all-link {
  font-size: 24rpx;
  color: #FF69B4;
  margin-left: 16rpx;
}

.selected-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.selected-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4F0);
  border-radius: 32rpx;
  border: 2rpx solid #FF69B4;
}

.tag-name {
  font-size: 24rpx;
  color: #FF69B4;
  font-weight: bold;
  margin-right: 8rpx;
}

.tag-close {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
  line-height: 1;
  padding: 0 4rpx;
}

.tag-close:active {
  opacity: 0.6;
}

/* ========== 最近联系人卡片 ========== */
.recent-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.recent-grid .contact-card {
  width: calc((100% - 32rpx) / 3);
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 20rpx 8rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  position: relative;
}

.recent-grid .contact-card:active {
  opacity: 0.7;
}

/* 选中状态 */
.recent-grid .contact-card.contact-selected {
  background: linear-gradient(135deg, #FFF0F5, #FFE4F0);
  border: 3rpx solid #FF69B4;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.25);
}

.recent-grid .add-contact {
  justify-content: center;
  background: linear-gradient(135deg, #FFF0F5, #FFFFFF);
}

.recent-grid .add-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  font-size: 36rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.recent-grid .add-contact text {
  font-size: 22rpx;
  color: #FF69B4;
  font-weight: bold;
}

.recent-grid .contact-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  flex-shrink: 0;
  border: 2rpx solid #FFE4F0;
}

/* 选中状态下的头像边框 */
.recent-grid .contact-card.contact-selected .contact-avatar {
  border: 3rpx solid #FF69B4;
}

/* 选中指示器（右上角对勾） */
.select-indicator {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 105, 180, 0.4);
}

.check-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.recent-grid .contact-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  text-align: center;
}

/* 选中状态下名字变粉色 */
.recent-grid .contact-card.contact-selected .contact-name {
  color: #FF69B4;
}

.recent-grid .contact-tag {
  font-size: 20rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  text-align: center;
  margin-top: 4rpx;
}

/* 推广横幅 */
.promo-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFF5F8);
  border-radius: 16rpx;
}

.promo-hover {
  opacity: 0.8;
}

.promo-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.promo-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.promo-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.promo-desc {
  font-size: 24rpx;
  color: #999999;
}

.promo-arrow {
  font-size: 32rpx;
  color: #FF69B4;
}
/* ========== 聊天节奏挡位选择 ========== */
.pace-section {
  margin-bottom: 24rpx;
}

.pace-levels-container {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.pace-level-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 8rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.pace-level-btn:active {
  opacity: 0.7;
}

.pace-level-btn.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.35);
}

.pace-level-percent {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 4rpx;
}

.pace-level-btn.active .pace-level-percent {
  color: #FFFFFF;
}

.pace-level-name {
  font-size: 22rpx;
  color: #999999;
}

.pace-level-btn.active .pace-level-name {
  color: #FFFFFF;
  font-weight: bold;
}

.pace-explanation {
  padding: 20rpx;
  background: #FFF5F8;
  border-radius: 16rpx;
}

.pace-current-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.pace-badge-percent {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF69B4;
  margin-right: 12rpx;
}

.pace-badge-name {
  font-size: 26rpx;
  color: #9B59B6;
  font-weight: bold;
}

.pace-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pace-detail-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.pace-detail-label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 8rpx;
  white-space: nowrap;
}

.pace-detail-text {
  font-size: 24rpx;
  color: #333333;
  flex: 1;
}

.pace-detail-example {
  font-size: 24rpx;
  color: #FF69B4;
  flex: 1;
}