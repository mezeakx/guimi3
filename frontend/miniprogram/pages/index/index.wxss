/* pages/index/index.wxss */

/* ========== Hero Banner ========== */
.hero-section {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 32rpx 8rpx 28rpx;
  margin-bottom: 0;
  position: relative;
}

.hero-left {
  flex: 1;
}

.hero-title-row {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 12rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #333333;
  display: inline;
  letter-spacing: 2rpx;
  line-height: 1;
}

.hero-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

.hero-illustration-inline {
  position: relative;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.bubble-main {
  width: 80rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #FF69B4, #FF8EC7);
  border-radius: 28rpx 28rpx 8rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.25);
}

.bubble-dots {
  font-size: 18rpx;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  font-weight: bold;
}

.deco-heart {
  font-size: 24rpx;
  margin-left: 4rpx;
  margin-top: -32rpx;
}

/* ========== Input Mode Tabs (胶囊风格) ========== */
.input-mode-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 105, 180, 0.06);
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999999;
  border-radius: 12rpx;
  transition: all 0.25s ease;
}

.tab.active {
  color: #FF69B4;
  background: linear-gradient(135deg, #FFF0F5, #FFE4F0);
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(255, 105, 180, 0.15);
}

.tab-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

/* ========== Card Container ========== */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(255, 105, 180, 0.06);
}

/* ========== Section ========== */
.section {
  margin-bottom: 28rpx;
}

.section:last-of-type {
  margin-bottom: 0;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-bar {
  display: inline-block;
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  background: linear-gradient(180deg, #FF69B4, #9B59B6);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #BBBBBB;
  font-weight: normal;
  margin-left: 4rpx;
}

/* Help Icon */
.help-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #FFB6C1;
  background: #FFF5F8;
  color: #FF69B4;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 12rpx;
  transition: all 0.2s ease;
}

.help-icon:active {
  background: #FF69B4;
  color: #FFFFFF;
}

/* ========== Input Fields ========== */
.input-field {
  width: 100%;
  background: #F8F8FA;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
}

.input-field:active {
  border-color: #FFB6C1;
}

.message-input {
  min-height: 160rpx;
  max-height: 400rpx;
}

.context-input {
  min-height: 80rpx;
  max-height: 240rpx;
}

.thought-custom-input {
  min-height: 80rpx;
  max-height: 200rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 8rpx;
}

/* ========== Thought Category Tabs ========== */
.thought-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 20rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 8rpx;
}

.thought-tabs::-webkit-scrollbar {
  height: 12rpx;
}

.thought-tabs::-webkit-scrollbar-track {
  background: #F5F5F5;
  border-radius: 3rpx;
}

.thought-tabs::-webkit-scrollbar-thumb {
  background: #CCCCCC;
  border-radius: 3rpx;
}

.thought-tabs::-webkit-scrollbar-thumb:active {
  background: #AAAAAA;
}

.thought-tab {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  margin-right: 12rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #777777;
  white-space: nowrap;
  transition: all 0.25s ease;
}

.thought-tab:active {
  opacity: 0.7;
}

.thought-tab.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.3);
}

.thought-tab text {
  font-size: 24rpx;
}

/* ========== Thought Options ========== */
.thought-options-wrapper {
  margin-bottom: 16rpx;
}

.thought-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.thought-option {
  padding: 12rpx 24rpx;
  background: #F8F8FA;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.25s ease;
}

.thought-option:active {
  opacity: 0.7;
}

.thought-option.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

/* ========== Relationship Tags ========== */
.relationship-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.rel-tag {
  padding: 10rpx 24rpx;
  background: #F8F8FA;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666666;
  transition: all 0.25s ease;
}

.rel-tag:active {
  opacity: 0.7;
}

.rel-tag.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.3);
}

/* ========== Pace Levels ========== */
.pace-section {
  margin-bottom: 28rpx;
}

.pace-levels-container {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.pace-level-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 4rpx;
  background: #F8F8FA;
  border-radius: 20rpx;
  transition: all 0.25s ease;
}

.pace-level-btn:active {
  opacity: 0.7;
}

.pace-level-btn.active {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  box-shadow: 0 6rpx 20rpx rgba(255, 105, 180, 0.35);
}

.pace-level-percent {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 4rpx;
}

.pace-level-btn.active .pace-level-percent {
  color: #FFFFFF;
}

.pace-level-name {
  font-size: 20rpx;
  color: #BBBBBB;
}

.pace-level-btn.active .pace-level-name {
  color: #FFFFFF;
  font-weight: bold;
}

/* ========== Pace Explanation ========== */
.pace-explanation {
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF5F8, #FFF0F5);
  border-radius: 20rpx;
  border: 2rpx solid #FFE4F0;
}

.pace-current-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.pace-badge-percent {
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-right: 12rpx;
}

.pace-badge-name {
  font-size: 26rpx;
  color: #9B59B6;
  font-weight: bold;
}

.pace-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pace-detail-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.pace-detail-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 8rpx;
  white-space: nowrap;
}

.pace-detail-text {
  font-size: 24rpx;
  color: #555555;
  flex: 1;
  line-height: 1.5;
}

.pace-detail-example {
  font-size: 24rpx;
  color: #FF69B4;
  flex: 1;
  line-height: 1.5;
}

/* ========== Submit Button ========== */
.submit-btn {
  width: 100%;
  margin-top: 24rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.35);
  transition: all 0.25s ease;
}

.submit-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.25);
}

.submit-btn:disabled {
  opacity: 0.5;
  transform: none;
  box-shadow: none;
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}

/* ========== Upload Area ========== */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  border: 4rpx dashed #FFB6C1;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFF5F8, #FFF0F5);
  margin-bottom: 28rpx;
  transition: all 0.25s ease;
}

.upload-area:active {
  border-color: #FF69B4;
}

.upload-area.has-image {
  padding: 0;
  border: none;
  background: transparent;
  position: relative;
  min-height: 200rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.8;
}

.upload-text {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #CCCCCC;
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  object-fit: contain;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  z-index: 10;
}

/* ========== Recent Contacts ========== */
.recent-section {
  margin-top: 32rpx;
}

.manage-link {
  font-size: 24rpx;
  color: #CCCCCC;
}

.selected-tags-section {
  margin-bottom: 24rpx;
}

.clear-all-link {
  font-size: 24rpx;
  color: #FF69B4;
  margin-left: 16rpx;
}

.selected-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.selected-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFE4F0);
  border-radius: 32rpx;
  border: 2rpx solid #FFB6C1;
}

.tag-name {
  font-size: 24rpx;
  color: #FF69B4;
  font-weight: bold;
  margin-right: 8rpx;
}

.tag-close {
  font-size: 28rpx;
  color: #FF69B4;
  font-weight: bold;
  line-height: 1;
  padding: 0 4rpx;
}

.tag-close:active {
  opacity: 0.6;
}

/* Contact Cards */
.recent-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.recent-grid .contact-card {
  width: calc((100% - 32rpx) / 3);
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 20rpx 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  position: relative;
  transition: transform 0.25s ease;
}

.recent-grid .contact-card:active {
  transform: scale(0.96);
}

.recent-grid .contact-card.contact-selected {
  background: linear-gradient(135deg, #FFF0F5, #FFE4F0);
  border: 3rpx solid #FF69B4;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.2);
}

.recent-grid .add-contact {
  justify-content: center;
  background: #FAFAFA;
}

.recent-grid .add-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  font-size: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 105, 180, 0.2);
}

.recent-grid .add-contact text {
  font-size: 22rpx;
  color: #FF69B4;
  font-weight: bold;
  margin-top: 8rpx;
}

.recent-grid .contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  flex-shrink: 0;
  border: 3rpx solid #FFE4F0;
}

.recent-grid .contact-card.contact-selected .contact-avatar {
  border: 3rpx solid #FF69B4;
}

.select-indicator {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 105, 180, 0.4);
}

.check-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.recent-grid .contact-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  text-align: center;
}

.recent-grid .contact-card.contact-selected .contact-name {
  color: #FF69B4;
}

.recent-grid .contact-tag {
  font-size: 20rpx;
  color: #CCCCCC;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
  text-align: center;
  margin-top: 6rpx;
}

/* ========== Promo Banner ========== */
.promo-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 105, 180, 0.25);
}

.promo-hover {
  opacity: 0.85;
}

.promo-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.promo-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.promo-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.promo-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.promo-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
  opacity: 0.7;
}

/* ========== Modal ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 580rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 16rpx 48rpx rgba(255, 105, 180, 0.15);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 40rpx;
}

.modal-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F9F9F9;
  transition: all 0.2s ease;
}

.modal-action-btn:active {
  opacity: 0.7;
}

.modal-action-icon {
  font-size: 32rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #F0F0F0;
}

.modal-action-add {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: bold;
}

.modal-action-select {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #FFFFFF;
}

.modal-action-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.modal-action-primary {
  background: #F9F9F9;
}

.modal-action-existing {
  background: #FFF0F5;
}

.modal-action-primary-text {
  color: #333333;
  font-weight: 500;
}
