/* pages/index/index.wxss */

/* 顶部标题区域 */
.header-section {
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-top: 8rpx;
}

.input-mode-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #FF69B4;
  border-bottom-color: #FF69B4;
  background: #FFF5F8;
}

.tab-icon {
  margin-right: 8rpx;
  font-size: 30rpx;
}

.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dot-pink { background: #FF69B4; }
.dot-purple { background: #9B59B6; }

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.help-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #999999;
  color: #999999;
  font-size: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8rpx;
}

.message-input {
  min-height: 200rpx;
  max-height: 400rpx;
}

.context-input {
  min-height: 120rpx;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.submit-btn:disabled {
  opacity: 0.6;
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  border: 4rpx dashed #FF69B4;
  border-radius: 16rpx;
  background: #FFF5F8;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #FF69B4;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
}

.recent-section {
  margin-top: 32rpx;
}

.manage-link {
  font-size: 24rpx;
  color: #999999;
}

.recent-scroll {
  white-space: nowrap;
  margin-top: 16rpx;
}

.recent-list {
  display: flex;
  flex-direction: row;
}

.contact-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  padding: 16rpx;
  margin-right: 16rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
}

.add-contact {
  justify-content: center;
}

.add-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF69B4, #FFB6C1);
  color: #FFFFFF;
  font-size: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 8rpx;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.contact-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.contact-tag {
  font-size: 20rpx;
  color: #999999;
}

/* 推广横幅 */
.promo-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF0F5, #FFF5F8);
  border-radius: 16rpx;
}

.promo-hover {
  opacity: 0.8;
}

.promo-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.promo-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.promo-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.promo-desc {
  font-size: 24rpx;
  color: #999999;
}

.promo-arrow {
  font-size: 32rpx;
  color: #FF69B4;
}
