/* pages/result/result.wxss */

page {
  background: #faf4f8;
  min-height: 100vh;
}

.page {
  padding: 0 30rpx;
  padding-bottom: 200rpx;
}

/* ========== 顶部标题区 ========== */
.page-header {
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.header-title-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.header-emoji {
  font-size: 40rpx;
}

.header-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #222;
  letter-spacing: 2rpx;
}

.header-subtitle {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
  line-height: 1.6;
}

/* ========== 通用卡片 ========== */
.card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(255, 105, 180, 0.08);
}

.card-inner {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.card-left {
  flex: 1;
}

.card-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.card-emoji {
  font-size: 36rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
}

.card-desc {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.card-illustration {
  font-size: 90rpx;
  line-height: 1;
}

/* ========== 标签 ========== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.4;
}

.tag-pink {
  background: #ffe0f0;
  color: #e91e8c;
}

.tag-warning {
  background: #fff7e6;
  color: #e67e22;
}

.tag-dot {
  font-size: 24rpx;
}

/* ========== 闺蜜提醒卡片（黄色调） ========== */
.remind-card {
  background: #fffdf7;
  border: 2rpx solid #fef3e2;
}

.remind-emoji {
  color: #e67e22;
}

/* ========== 推荐回复区域 ========== */
.reply-section {
  margin-bottom: 28rpx;
}

.reply-section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.reply-heart {
  font-size: 32rpx;
}

.reply-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
}

.reply-subtitle {
  font-size: 26rpx;
  color: #bbb;
}

/* ========== 回复卡片通用 ========== */
.reply-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 105, 180, 0.06);
  position: relative;
  overflow: hidden;
}

.reply-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 0 0 0 160rpx;
  opacity: 0.04;
  pointer-events: none;
}

.reply-card-default::before {
  background: #FF69B4;
}

.reply-card-purple::before {
  background: #9B59B6;
}

.reply-card-orange::before {
  background: #F59E0B;
}

.reply-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reply-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reply-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #FF69B4;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.reply-style {
  font-size: 28rpx;
  font-weight: 600;
}

.style-pink {
  color: #FF69B4;
}

.style-purple {
  color: #9B59B6;
}

.style-orange {
  color: #F59E0B;
}

/* ========== 复制按钮 ========== */
.copy-btn {
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  border: 2rpx solid;
  background: #fff;
  margin: 0;
  height: auto;
  width: auto;
  min-width: 0;
  box-sizing: border-box;
  flex-shrink: 0;
  flex-grow: 0;
  margin-left: auto;
}

.copy-btn::after {
  border: none;
}

.copy-btn-pink {
  color: #FF69B4;
  border-color: #ffb6d9;
}

.copy-btn-purple {
  color: #9B59B6;
  border-color: #d4b5e0;
}

.copy-btn-orange {
  color: #F59E0B;
  border-color: #fde0a0;
}

.copy-icon {
  font-size: 24rpx;
}

/* ========== 回复正文 ========== */
.reply-text {
  font-size: 34rpx;
  color: #222;
  line-height: 1.7;
  margin-top: 20rpx;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* ========== 回复元信息 ========== */
.reply-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 24rpx;
  padding-top: 12rpx;
}

.meta-chip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #f8f4fa;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 22rpx;
  color: #888;
}

.meta-label {
  white-space: nowrap;
}

.meta-value {
  color: #888;
  white-space: nowrap;
}

.star-row {
  display: inline-flex;
  gap: 2rpx;
}

.star {
  font-size: 22rpx;
  color: #ddd;
}

.star.filled {
  color: #ffc107;
}

.star.empty {
  color: #eee;
}

/* ========== 风格切换卡片 ========== */
.style-switch-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  box-shadow: 0 6rpx 20rpx rgba(255, 105, 180, 0.05);
}

.style-switch-left {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.style-lightbulb {
  font-size: 44rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.style-switch-texts {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.style-switch-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF69B4;
}

.style-switch-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.arrow-right {
  font-size: 36rpx;
  color: #FFB6D9;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ========== 底部按钮 ========== */
.bottom-actions {
  display: flex;
  gap: 24rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.btn-replace {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid #FF69B4;
  color: #FF69B4;
  font-size: 32rpx;
  font-weight: 700;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.btn-replace::after {
  border: none;
}

.btn-regenerate {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #FF69B4 0%, #9B59B6 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.btn-regenerate::after {
  border: none;
}

.btn-replace-icon,
.btn-regen-emoji {
  font-size: 32rpx;
}

/* ========== 动画 ========== */
.card-anim {
  animation: fadeInUp 0.4s ease-out both;
}

.reply-card:nth-child(1) { animation-delay: 0.1s; }
.reply-card:nth-child(2) { animation-delay: 0.2s; }
.reply-card:nth-child(3) { animation-delay: 0.3s; }

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}