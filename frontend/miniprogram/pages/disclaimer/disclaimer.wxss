/* pages/disclaimer/disclaimer.wxss */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-body {
  font-size: 26rpx;
  color: #666666;
  line-height: 2;
  margin-bottom: 32rpx;
  text-align: center;
}

.modal-btn {
  width: 100%;
  padding: 20rpx 0;
  font-size: 28rpx;
}
