.container { padding: 24rpx; }
.section { margin-bottom: 24rpx; }
.label { font-size: 30rpx; color: #333; font-weight: bold; margin-bottom: 12rpx; display: block; }
.textarea { width: 100%; height: 200rpx; border: 1rpx solid #eee; border-radius: 12rpx; padding: 16rpx; box-sizing: border-box; }
.input { width: 100%; height: 80rpx; border: 1rpx solid #eee; border-radius: 12rpx; padding: 0 16rpx; box-sizing: border-box; }
.upload-area { width: 200rpx; height: 200rpx; border: 1rpx dashed #ccc; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.upload-area text { color: #999; font-size: 24rpx; }
.submit-btn { margin-top: 40rpx; }
