/* pages/contact-create/contact-create.wxss */

/* ========== 容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f9 0%, #ffffff 40%);
  padding-bottom: 200rpx;
}

/* ========== 卡片容器 ========== */
.card {
  margin: 20rpx 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 105, 180, 0.08);
}

/* ========== 区块标题 ========== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF69B4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-icon-text {
  font-size: 28rpx;
  line-height: 1;
}

/* SVG图标样式 */
.section-icon-img {
  width: 24rpx;
  height: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.char-count,
.identity-count,
.target-count,
.style-count {
  font-size: 26rpx;
  color: #FF69B4;
  font-weight: 500;
}

/* ========== 输入框 ========== */
.input-field {
  width: 100%;
  height: 88rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: #cccccc;
}

/* ========== 选项网格布局 ========== */
.option-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.option-item {
  flex: 0 0 calc(33.33% - 10rpx);
  background: #ffffff;
  border: 4rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 19rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  box-sizing: border-box;
  min-width: 0;
}

.option-emoji {
  font-size: 38rpx;
  line-height: 1;
}

.option-label {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  line-height: 1.4;
  word-break: break-all;
}

/* ========== 选中状态 ========== */
.option-item.selected {
  background: #fff9fc;
  border: 4rpx solid #FF69B4;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 105, 180, 0.15);
}

.option-item.selected .option-label {
  color: #FF69B4;
  font-weight: 600;
}

/* ========== 底部悬浮保存按钮 ========== */
.save-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18rpx 30rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-gradient {
  width: 100%;
  height: 87rpx;
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.btn-gradient:active {
  opacity: 0.85;
  transform: scale(0.98);
}