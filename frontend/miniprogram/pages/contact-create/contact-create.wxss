/* pages/contact-create/contact-create.wxss */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.char-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #999999;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.option-item {
  display: flex;
  justify-content: center;
  align-items: center;
  width: calc(25% - 12rpx);
  height: 80rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  background: #FFFFFF;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.option-item.selected {
  background: #FFF0F5;
  border-color: #FF69B4;
  color: #FF69B4;
  font-weight: bold;
}

.save-btn {
  width: calc(100vw - 48rpx);
  position: fixed;
  bottom: 120rpx;
  left: 24rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
  z-index: 10;
}
