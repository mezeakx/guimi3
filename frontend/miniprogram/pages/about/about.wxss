/* pages/about/about.wxss */

.page-container {
  min-height: 100vh;
  background: #FAFAFA;
  padding-bottom: 60rpx;
}

/* ========== Brand Section ========== */
.brand-section {
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  justify-content: center;
}

.brand-card {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 105, 180, 0.3);
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.25);
  padding: 12rpx;
  margin-bottom: 20rpx;
}

.brand-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
}

.brand-version {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 6rpx 20rpx;
}

.version-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* ========== Features Section ========== */
.features-section {
  margin: 32rpx 32rpx 0;
}

.section-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-emoji {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.feature-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.feature-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #FFF0F5, #F3E8FF);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.feature-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

/* ========== Philosophy Section ========== */
.philosophy-section {
  margin: 40rpx 32rpx 0;
}

.philosophy-card {
  background: linear-gradient(135deg, #FFF5F8, #F3E8FF);
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.philosophy-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.philosophy-main {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  font-weight: 500;
}

/* ========== Footer Section ========== */
.footer-section {
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.footer-divider {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #FF69B4, transparent);
  border-radius: 2rpx;
  margin-bottom: 32rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #CCCCCC;
  letter-spacing: 1rpx;
}
