<!--pages/about/about.wxml-->
<view class="page-container">
  <!-- Logo & Brand Section -->
  <view class="brand-section">
    <view class="brand-card">
      <image class="brand-logo" src="/assets/images/logo.png" mode="aspectFit" />
      <text class="brand-name">闺蜜帮你回</text>
      <text class="brand-subtitle">你的高情商聊天小助手 ✨</text>
      <view class="brand-version">
        <text class="version-tag">v{{version}}</text>
      </view>
    </view>
  </view>

  <!-- Features Section -->
  <view class="features-section">
    <view class="section-title">
      <text class="section-emoji">💡</text>
      <text class="section-heading">我们能做什么</text>
    </view>
    <view class="feature-list">
      <view class="feature-item">
        <view class="feature-icon">💬</view>
        <view class="feature-info">
          <text class="feature-title">聊天分析</text>
          <text class="feature-desc">智能分析聊天内容，帮你理解对方的真实意图</text>
        </view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">🎯</view>
        <view class="feature-info">
          <text class="feature-title">回复建议</text>
          <text class="feature-desc">AI 生成高情商回复建议，让你不再词穷</text>
        </view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">🛡️</view>
        <view class="feature-info">
          <text class="feature-title">风险提示</text>
          <text class="feature-desc">识别聊天中的潜在风险，避免踩雷尴尬</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Philosophy Section -->
  <view class="philosophy-section">
    <view class="philosophy-card">
      <text class="philosophy-emoji">💝</text>
      <text class="philosophy-main">我们不是替用户谈恋爱，而是帮助用户更好表达自己。</text>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer-section">
    <view class="footer-divider"></view>
    <text class="footer-text">Made with ❤️  愿每一段对话都真诚动人</text>
  </view>
</view>
