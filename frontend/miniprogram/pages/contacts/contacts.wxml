<!--pages/contacts/contacts.wxml-->
<view class="phone-container">
  <!-- 状态栏占位 -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <!-- 主标题与描述区域 -->
  <view class="header-section">
    <view class="header-text">
      <text class="header-title">我的联系人</text>
      <text class="header-heart">💘</text>
      <text class="header-desc">管理你的聊天对象，获取专属回复建议</text>
    </view>
    <view class="header-decor">
      <image class="decor-icon" src="/assets/icons/contacts-decor.svg" mode="aspectFit"/>
    </view>
  </view>

  <!-- 白色圆角卡片面板 -->
  <view class="card-panel">
    <!-- 空状态内容 -->
    <view class="empty-content" wx:if="{{contacts.length === 0}}">
      <view class="empty-illustration">
        <image class="empty-svg" src="/assets/images/empty-contact-center.png" mode="aspectFit"/>
      </view>
      <text class="empty-heading">还没有联系人哦</text>
      <text class="empty-sub">添加联系人，为Ta定制专属的回复建议</text>
      <text class="empty-bounce">💕</text>
      <button class="btn-add-first" bindtap="goToCreate">
        <text class="btn-plus">+</text>
        <text class="btn-text">添加第一个联系人</text>
      </button>
    </view>

    <!-- 联系人列表 -->
    <view class="contact-list" wx:else>
      <view class="contact-card" wx:for="{{contacts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="contact-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill"/>
        <view class="contact-info">
          <text class="contact-name">{{item.nickname}}</text>
          <text class="contact-tag">{{item.identity_label}}</text>
        </view>
        <image class="arrow-icon" src="/assets/icons/arrow-right.svg" mode="aspectFit"/>
        <!-- 删除按钮 -->
        <view class="delete-btn" catchtap="deleteContact" data-id="{{item.id}}">
          <image class="delete-icon" src="/assets/icons/delete.svg" mode="aspectFit"/>
        </view>
      </view>
    </view>
  </view>

  <!-- 浮动添加按钮 (移到 card-panel 外部) -->
  <view class="fab-container" wx:if="{{contacts.length > 0}}" style="left: {{fabLeft}}px; bottom: {{fabBottom}}px;">
    <view class="fab-btn {{fabDragging ? 'fab-dragging' : 'fab-normal'}}"
      bindtouchstart="onFabTouchStart"
      bindtouchmove="onFabTouchMove"
      bindtouchend="onFabTouchEnd"
      bindtap="toggleDrawer">
      <text class="fab-plus">+</text>
    </view>
  </view>

  <!-- 抽屉遮罩层 -->
  <view class="drawer-overlay" wx:if="{{showDrawer}}" bindtap="toggleDrawer"></view>

  <!-- 抽屉式添加联系人弹窗 -->
  <view class="drawer" wx:if="{{showDrawer}}">
    <view class="drawer-handle"></view>
    <text class="drawer-title">添加联系人</text>

    <view class="drawer-form">
      <view class="form-item">
        <text class="form-label">联系人姓名/昵称</text>
        <input class="form-input" placeholder="例如：小美" value="{{newContact.nickname}}" bindinput="onNicknameInput" maxlength="20"/>
      </view>

      <view class="form-item">
        <text class="form-label">与你的关系</text><text class="optional">(选填)</text>
        <input class="form-input" placeholder="例如：朋友、合作伙伴、暗恋对象" value="{{newContact.identity_label}}" bindinput="onIdentityInput" maxlength="30"/>
      </view>

      <button class="btn-gradient drawer-submit" bindtap="submitContact">确认添加</button>
    </view>
  </view>
</view>