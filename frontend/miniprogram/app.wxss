/* 全局样式 */
page {
  background-color: #FFF5F8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(255, 105, 180, 0.08);
}

/* 渐变按钮 */
.btn-gradient {
  background: linear-gradient(135deg, #FF69B4, #9B59B6);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

.btn-gradient[disabled] {
  background: #cccccc;
  opacity: 0.6;
}

/* 间距 */
.mt-24 { margin-top: 24rpx; }
.mb-24 { margin-bottom: 24rpx; }

/* Flex 工具类 */
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 标签 */
.subtitle {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}
