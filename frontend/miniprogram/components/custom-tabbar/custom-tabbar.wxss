/* components/custom-tabbar/custom-tabbar.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #FFFFFF;
  border-top: 1rpx solid #F0F0F0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 8rpx;
  padding-bottom: 16rpx;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-text {
  font-size: 22rpx;
  margin-top: 4rpx;
  color: #999999;
}

.tab-bar-item.active .tab-text {
  color: #FF69B4;
}

/* ========== 首页 - 聊天气泡 ========== */
.tab-icon--chat {
  position: relative;
}

.chat-bubble {
  width: 36rpx;
  height: 28rpx;
  border: 3rpx solid #999999;
  border-radius: 8rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.chat-bubble::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 10rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 10rpx solid #999999;
}

.chat-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #999999;
}

.tab-bar-item.active .chat-bubble {
  border-color: #FF69B4;
}

.tab-bar-item.active .chat-bubble::after {
  border-top-color: #FF69B4;
}

.tab-bar-item.active .chat-dot {
  background: #FF69B4;
}

/* ========== 联系人 - 双人 ========== */
.person {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.person--primary {
  left: 6rpx;
  top: 4rpx;
  z-index: 2;
}

.person--secondary {
  right: 2rpx;
  top: 10rpx;
  z-index: 1;
  opacity: 0.55;
}

.person-head {
  width: 14rpx;
  height: 14rpx;
  border: 2.5rpx solid #999999;
  border-radius: 50%;
}

.person-body {
  width: 20rpx;
  height: 10rpx;
  border: 2.5rpx solid #999999;
  border-top: none;
  border-radius: 0 0 10rpx 10rpx;
  margin-top: -2rpx;
}

.tab-bar-item.active .person--primary .person-head {
  border-color: #FF69B4;
}

.tab-bar-item.active .person--primary .person-body {
  border-color: #FF69B4;
}

.tab-bar-item.active .person--secondary .person-head {
  border-color: #FF69B4;
}

.tab-bar-item.active .person--secondary .person-body {
  border-color: #FF69B4;
}

/* ========== 我的 - 笑脸 ========== */
.smile-face {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #999999;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 4rpx;
  padding-top: 4rpx;
}

.smile-eye {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: #999999;
}

.smile-mouth {
  width: 16rpx;
  height: 8rpx;
  border-bottom: 3rpx solid #999999;
  border-radius: 0 0 8rpx 8rpx;
  margin-top: -2rpx;
}

.tab-bar-item.active .smile-face {
  border-color: #FF69B4;
}

.tab-bar-item.active .smile-eye {
  background: #FF69B4;
}

.tab-bar-item.active .smile-mouth {
  border-bottom-color: #FF69B4;
}
